# Notion 内部连接的只读密钥；真实值只写入未提交的 .env。
NOTION_TOKEN=

# Notion 网站内容数据库的数据源 ID。
NOTION_DATA_SOURCE_ID=

# 默认阻止零篇已发布内容覆盖线上站点；确实需要发布空站时才改为 true。
ALLOW_EMPTY_SITE=false

# Cloudflare Pages Direct Upload 项目名；首次部署前运行 npm run pages:create。
CLOUDFLARE_PAGES_PROJECT=

# 可选：本机可使用 Wrangler OAuth；CI 环境填写 API Token 和账户 ID。
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
