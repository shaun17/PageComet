---
import type { ContentEntry } from "../lib/notion";
import type { CategoryDefinition } from "../content/categories";
import { getEntryHref } from "../content/site-content";

interface Props {
  category: CategoryDefinition;
  entries: ContentEntry[];
}

const { category, entries } = Astro.props;
const headingId = `directory-${category.key}`;
// 流水账在首页只保留分类入口；其他分类继续展示前三条目录。
const showsEntryDirectory = category.key !== "journal";
const visibleEntries = showsEntryDirectory ? entries.slice(0, 3) : [];
---

<section
  class:list={["directory-column", { "directory-column-entry-only": !showsEntryDirectory }]}
  aria-labelledby={headingId}
>
  <div class="column-heading">
    <span class="column-index" aria-hidden="true">{category.index}</span>
    <h2 id={headingId}><a href={category.path}>{category.label}</a></h2>
  </div>

  {
    showsEntryDirectory && (
      <ul class="directory-links">
        {visibleEntries.map((entry) => (
          <li>
            <a href={getEntryHref(entry)}>{entry.title}</a>
          </li>
        ))}
        <li><a class="more-link" href={category.path}>更多</a></li>
      </ul>
    )
  }
</section>
