---
import type { ContentBlock, ContentRichText } from "../lib/notion";
import { renderRichText, richTextToPlainText } from "../content/render-rich-text";
import { normalizeContentHref } from "../content/content-href";
import NotionLinkPreview from "./NotionLinkPreview.astro";
import NotionMedia from "./NotionMedia.astro";

interface Props {
  blocks: ContentBlock[];
}

type BlockGroup =
  | { kind: "bulleted" | "numbered"; blocks: ContentBlock[] }
  | { kind: "single"; blocks: [ContentBlock] };

const { blocks } = Astro.props;

interface SafeBlockUrl {
  href: string;
  external: boolean;
}

/** 书签接受站内相对路径和 HTTP(S) 地址，并区分是否需要新窗口打开。 */
const safeBlockUrl = (value: string | undefined): SafeBlockUrl | null => {
  const href = normalizeContentHref(value);
  if (!href || href.kind === "email") return null;
  return { href: href.href, external: href.kind === "external" };
};

/** 只有独占段落的单个链接才提升为摘要卡，句子中的链接继续保持行内阅读节奏。 */
const readStandaloneLinkPreview = (item: ContentBlock): ContentRichText | null => {
  if (item.type !== "paragraph" || item.richText.length !== 1) return null;
  const span = item.richText[0];
  return span?.href && span.linkPreview ? span : null;
};

/** 将连续的 Notion 列表项合并为一个语义正确的 ul 或 ol。 */
const groupBlocks = (items: ContentBlock[]): BlockGroup[] => {
  const groups: BlockGroup[] = [];
  for (const item of items) {
    const kind =
      item.type === "bulleted_list_item"
        ? "bulleted"
        : item.type === "numbered_list_item"
          ? "numbered"
          : null;
    const previous = groups.at(-1);
    if (kind && previous?.kind === kind) {
      previous.blocks.push(item);
    } else if (kind) {
      groups.push({ kind, blocks: [item] });
    } else {
      groups.push({ kind: "single", blocks: [item] });
    }
  }
  return groups;
};

const groups = groupBlocks(blocks);
---

{
  groups.map((group) => {
    if (group.kind === "bulleted" || group.kind === "numbered") {
      const List = group.kind === "bulleted" ? "ul" : "ol";
      return (
        <List>
          {group.blocks.map((item) => (
            <li>
              <span set:html={renderRichText(item.richText)} />
              {item.children.length > 0 && <Astro.self blocks={item.children} />}
            </li>
          ))}
        </List>
      );
    }

    const item = group.blocks[0];
    const bookmark = safeBlockUrl(item.url);
    const standaloneLinkPreview = readStandaloneLinkPreview(item);
    return (
      <>
        {item.type === "paragraph" && standaloneLinkPreview && (
          <NotionLinkPreview
            id={item.id}
            href={standaloneLinkPreview.href!}
            label={standaloneLinkPreview.plainText}
            preview={standaloneLinkPreview.linkPreview!}
            nativeMention={standaloneLinkPreview.type === "mention"}
          />
        )}
        {item.type === "paragraph" && !standaloneLinkPreview && (
          <p set:html={renderRichText(item.richText)} />
        )}
        {item.type === "heading_1" && (
          <h2 set:html={renderRichText(item.richText, { previewMode: "mention" })} />
        )}
        {item.type === "heading_2" && (
          <h3 set:html={renderRichText(item.richText, { previewMode: "mention" })} />
        )}
        {item.type === "heading_3" && (
          <h4 set:html={renderRichText(item.richText, { previewMode: "mention" })} />
        )}
        {item.type === "quote" && <blockquote set:html={renderRichText(item.richText)} />}
        {item.type === "callout" && (
          <aside class="notion-callout">
            {item.icon && <span aria-hidden="true">{item.icon}</span>}
            <div>
              <p set:html={renderRichText(item.richText)} />
              {item.children.length > 0 && <Astro.self blocks={item.children} />}
            </div>
          </aside>
        )}
        {item.type === "to_do" && (
          <div class="notion-todo">
            <input type="checkbox" checked={item.checked} disabled aria-hidden="true" />
            <span set:html={renderRichText(item.richText)} />
          </div>
        )}
        {item.type === "toggle" && (
          <details>
            <summary set:html={renderRichText(item.richText, { previewMode: "mention" })} />
            {item.children.length > 0 && <Astro.self blocks={item.children} />}
          </details>
        )}
        {item.type === "code" && (
          <figure class="notion-code">
            <pre><code data-language={item.language}>{richTextToPlainText(item.richText)}</code></pre>
            {item.caption && item.caption.length > 0 && (
              <figcaption>{richTextToPlainText(item.caption)}</figcaption>
            )}
          </figure>
        )}
        {["image", "video", "embed"].includes(item.type) && <NotionMedia item={item} />}
        {(item.type === "bookmark" || item.type === "link_preview") &&
          bookmark &&
          item.linkPreview && (
            <NotionLinkPreview
              id={item.id}
              href={bookmark.href}
              label={richTextToPlainText(item.caption) || item.url || bookmark.href}
              preview={item.linkPreview}
            />
          )}
        {(item.type === "bookmark" || item.type === "link_preview") &&
          bookmark &&
          !item.linkPreview && (
          <p class="notion-bookmark">
            <a
              class={`notion-mention notion-mention-${bookmark.external ? "external" : "internal"}`}
              href={bookmark.href}
              target={bookmark.external ? "_blank" : undefined}
              rel={bookmark.external ? "noopener noreferrer" : undefined}
            >
              <span class="notion-mention-mark" aria-hidden="true">
                {bookmark.external ? "↗" : "→"}
              </span>
              <span class="notion-mention-label">
                {richTextToPlainText(item.caption) || item.url}
              </span>
            </a>
          </p>
        )}
        {item.type === "equation" && <p class="notion-equation">{item.expression}</p>}
        {item.type === "divider" && (
          <div class="notion-divider" role="separator">
            <span aria-hidden="true">·—·</span>
          </div>
        )}
        {item.type === "table" && (
          <div class="notion-table-wrap">
            <table>
              <tbody>
                {item.children.map((row, rowIndex) => (
                  <tr>
                    {(row.cells ?? []).map((cell) =>
                      item.table?.hasColumnHeader && rowIndex === 0 ? (
                        <th scope="col" set:html={renderRichText(cell)} />
                      ) : (
                        <td set:html={renderRichText(cell)} />
                      ),
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        {item.type === "column_list" && (
          <div class="notion-columns">
            {item.children.map((column) => (
              <section><Astro.self blocks={column.children} /></section>
            ))}
          </div>
        )}
        {(item.type === "column" || item.type === "synced_block") && (
          <Astro.self blocks={item.children} />
        )}
        {["paragraph", "heading_1", "heading_2", "heading_3", "quote"].includes(item.type) &&
          item.children.length > 0 && <Astro.self blocks={item.children} />}
      </>
    );
  })
}

<script>
  const inlineLinkPreviews = document.querySelectorAll<HTMLElement>(
    ".notion-link:not(.notion-link-card)",
  );

  /** 浮层打开前根据视口边界选择左右和上下方向，避免摘要制造横向滚动。 */
  const positionLinkPreview = (wrapper: HTMLElement) => {
    const preview = wrapper.querySelector<HTMLElement>(".notion-link-preview");
    if (!preview) return;
    wrapper.removeAttribute("data-preview-place");
    wrapper.style.removeProperty("--notion-link-preview-shift");
    const wrapperRect = wrapper.getBoundingClientRect();
    const previewRect = preview.getBoundingClientRect();
    const edge = 16;
    const maximumLeft = Math.max(edge, window.innerWidth - edge - previewRect.width);
    const clampedLeft = Math.min(Math.max(previewRect.left, edge), maximumLeft);
    wrapper.style.setProperty(
      "--notion-link-preview-shift",
      `${clampedLeft - previewRect.left}px`,
    );
    if (
      wrapperRect.bottom + previewRect.height + edge > window.innerHeight &&
      wrapperRect.top > previewRect.height + edge
    ) {
      wrapper.dataset.previewPlace = "above";
    }
  };

  for (const wrapper of inlineLinkPreviews) {
    /** 再次指向 mention 时解除 Escape 关闭状态并重新计算边界。 */
    wrapper.addEventListener("pointerenter", () => {
      wrapper.removeAttribute("data-preview-dismissed");
      positionLinkPreview(wrapper);
    });
    wrapper.addEventListener("focusin", () => {
      wrapper.removeAttribute("data-preview-dismissed");
      positionLinkPreview(wrapper);
    });
    /** 键盘用户可以在焦点仍留在链接上时关闭遮挡正文的浮层。 */
    wrapper.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      wrapper.setAttribute("data-preview-dismissed", "");
      event.preventDefault();
    });
    wrapper.addEventListener("focusout", (event) => {
      if (event.relatedTarget instanceof Node && wrapper.contains(event.relatedTarget)) return;
      wrapper.removeAttribute("data-preview-dismissed");
    });
  }

  let resizeFrame = 0;
  /** 视口变化后只在下一帧批量重算，避免浮层沿用过期的位置。 */
  window.addEventListener("resize", () => {
    cancelAnimationFrame(resizeFrame);
    resizeFrame = requestAnimationFrame(() => {
      for (const wrapper of inlineLinkPreviews) positionLinkPreview(wrapper);
    });
  });
</script>
