---
import type { ContentEntry } from "../../lib/notion";
import ArticlePage from "../../components/ArticlePage.astro";
import { getSiteContent } from "../../content/site-content";

/** 为文章型分类生成详情页；流水账只公开统一时间流，不生成永久链接。 */
export async function getStaticPaths() {
  const entries = await getSiteContent();
  return entries
    .filter((entry) => entry.category !== "journal")
    .map((entry) => ({
      params: { category: entry.category, slug: entry.slug },
      props: { entry },
    }));
}

interface Props {
  entry: ContentEntry;
}

const { entry } = Astro.props;
---

<ArticlePage entry={entry} />
