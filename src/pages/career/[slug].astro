---
import type { ContentEntry } from "../../lib/notion";
import ArticlePage from "../../components/ArticlePage.astro";
import { getCategoryEntries } from "../../content/site-content";

/** 为每条已发布职业经历生成站内静态详情页。 */
export async function getStaticPaths() {
  const entries = await getCategoryEntries("career");
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: ContentEntry;
}

const { entry } = Astro.props;
---

<ArticlePage entry={entry} />
