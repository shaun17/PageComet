---
import DecimalYear from "../components/DecimalYear.astro";
import DirectoryColumn from "../components/DirectoryColumn.astro";
import FooterDetails from "../components/FooterDetails.astro";
import { ORDERED_CATEGORIES } from "../content/categories";
import { getSiteContent } from "../content/site-content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { siteConfig } from "../config/runtime-site-config";

const entries = await getSiteContent();
const headlineCategory = ORDERED_CATEGORIES.find(
  (category) => category.key === siteConfig.home.headline.categoryKey,
);
if (!headlineCategory) throw new Error("首页标题指向了不存在的分类");
---

<SiteLayout>
  <main class="site-shell">
    <section class="hero" aria-labelledby="hero-title">
      <p class="hero-kicker">{siteConfig.brand.kicker}</p>

      <h1 id="hero-title">{siteConfig.home.headline.prefix}<a href={headlineCategory.path}>{siteConfig.home.headline.linkLabel}</a>{siteConfig.home.headline.suffix}</h1>
    </section>

    <section class="home-information" aria-label="个人信息">
      <DecimalYear />

      <div class="hero-meta" aria-label="个人简介">
        {siteConfig.home.biography.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <footer class="site-footer">
        <nav class="directory" aria-label="内容目录">
          {
            ORDERED_CATEGORIES.map((category) => (
              <DirectoryColumn
                category={category}
                entries={entries.filter((entry) => entry.category === category.key)}
              />
            ))
          }
        </nav>
        <FooterDetails />
      </footer>
    </section>
  </main>
</SiteLayout>
